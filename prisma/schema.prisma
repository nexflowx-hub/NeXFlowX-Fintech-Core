generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  operator
  viewer
  merchant
  customer
}

enum TransactionStatus {
  pending
  gateway_confirmed
  failed
  settled
}

// ==========================================
// 🏢 BAAS: ORGANIZAÇÕES (Novo Atlas Core)
// ==========================================
model Organization {
  id              String   @id @default(cuid())
  name            String
  registration_id String?  // NIF/CNPJ da empresa mãe
  country         String?
  created_at      DateTime @default(now())
  
  users           User[]
}

// ==========================================
// 👤 UTILIZADORES & AUTENTICAÇÃO
// ==========================================
model User {
  id                 String          @id @default(cuid())
  username           String          @unique
  password_hash      String
  role               Role            @default(customer)
  tier               String          @default("NEW") // AAA, A, B, C, NEW
  overrideFeeInEur   Decimal? 
  overrideFeeInBrl   Decimal?
  overrideFeeSwap    Decimal?
  overrideFeeOutCrypto Decimal?
  overrideFeeOutPix    Decimal?
  overrideFeeOutSepa   Decimal?
  metadata             Json?
  maxVolumeMonthly   Decimal         @default(10000) 

  // --- 🏢 LIGAÇÃO À ORGANIZAÇÃO (Atlas BaaS) ---
  organizationId     String?
  organization       Organization?   @relation(fields: [organizationId], references: [id])
  isActive           Boolean         @default(true)

  // --- 🔒 SEGURANÇA & ACESSO ---
  email              String?         @unique
  email_verified     Boolean         @default(false)
  phone              String?         @unique
  two_factor_secret  String?
  twoFactorEnabled   Boolean         @default(false)

  // --- 🔔 NOTIFICAÇÕES (Atlas BaaS) ---
  emailNotifications Boolean         @default(true)
  transactionAlerts  Boolean         @default(true)
  weeklyReports      Boolean         @default(false)
  securityAlerts     Boolean         @default(true)

  // --- 🛂 KYC & COMPLIANCE ---
  full_name          String?
  country            String?
  tax_id             String?
  kyc_level          Int             @default(0)

  // --- 🤖 INTEGRAÇÃO CRM / CHATWOOT ---
  chatwoot_contact_id String?

  // --- RELAÇÕES ---
  webhook_url        String?
  webhook_secret     String?

  stores             Store[]
  transactions       Transaction[]
  apiKeys            ApiKey[]
  gateway_configs    GatewayConfig[]
  wallets            Wallet[]
  payouts            Payout[]
  paymentLinks       PaymentLink[]
  
  // --- NOVAS RELAÇÕES ATLAS ---
  auditLogs          AuditLog[]
  actionTickets      ActionTicket[]
  sessions           Session[]

  created_at         DateTime        @default(now())
  lastLogin          DateTime?
}

// ==========================================
// 🛡️ SESSÕES & AUDITORIA (Novo Atlas Core)
// ==========================================
model Session {
  id              String    @id @default(cuid())
  userId          String
  token           String    @unique
  expiresAt       DateTime
  createdAt       DateTime  @default(now())
  
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id              String    @id @default(cuid())
  userId          String?
  action          String
  entityType      String
  entityId        String
  oldValue        String?   
  newValue        String?   
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime  @default(now())
  
  user            User?     @relation(fields: [userId], references: [id])
}

model ActionTicket {
  id              String    @id @default(cuid())
  userId          String
  type            String    // Ex: "withdrawal_limit_increase", "kyc_approval"
  status          String    @default("pending") // pending, approved, rejected
  payload         Json?     
  adminNotes      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  user            User      @relation(fields: [userId], references: [id])
}

model Currency {
  code            String        @id
  type            String
  precision       Int
  is_active       Boolean       @default(true)
  wallets         Wallet[]
  ledgerEntries   LedgerEntry[]
  created_at      DateTime      @default(now())
}

// ==========================================
// 🏪 MODELO SAAS (MULTI-TENANT & MARCAS)
// ==========================================
model Store {
  id                 String          @id @default(cuid())
  name               String
  logo_url           String?
  primary_color      String          @default("#111111")
  accent_color       String          @default("#00FF41")

  webhook_url        String?
  webhook_secret     String?
  whatsapp_number    String?
  chatwoot_inbox_id  String?

  user_id            String
  user               User            @relation(fields: [user_id], references: [id])

  gateways           GatewayConfig[]
  transactions       Transaction[]
  paymentLinks       PaymentLink[]
  created_at         DateTime        @default(now())
}

// ==========================================
// 💳 MOTOR DE GATEWAYS & SMART ROUTING
// ==========================================
model GatewayConfig {
  id                 String   @id @default(cuid())
  provider_name      String
  api_key            String?  
  merchant_id        String?  
  is_active          Boolean  @default(true)

  master_provider_id String?
  master_provider    MasterProvider? @relation(fields: [master_provider_id], references: [id])
  routing_rules      Json?

  user_id            String
  user               User     @relation(fields: [user_id], references: [id])
  store_id           String?
  store              Store?   @relation(fields: [store_id], references: [id])

  created_at         DateTime @default(now())
  @@unique([user_id, provider_name, store_id])
}

// ==========================================
// 🏦 CORE BANK (LEDGER & WALLETS)
// ==========================================
model Wallet {
  id                String        @id @default(cuid())
  user_id           String
  currency_code     String
  currency          Currency      @relation(fields: [currency_code], references: [code])
  type              String        @default("merchant")
  balance_incoming  Decimal       @db.Decimal(20, 8) @default(0.0)
  balance_pending   Decimal       @db.Decimal(20, 8) @default(0.0)
  balance_available Decimal       @db.Decimal(20, 8) @default(0.0)

  user              User          @relation(fields: [user_id], references: [id])
  entries           LedgerEntry[]

  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt
  @@unique([user_id, currency_code, type])
}

model LedgerTransaction {
  id              String        @id @default(cuid())
  type            String
  status          String        @default("pending")
  reference_id    String?
  description     String?
  entries         LedgerEntry[]
  created_at      DateTime      @default(now())
  cleared_at      DateTime?
}

model LedgerEntry {
  id                    String            @id @default(cuid())
  ledger_transaction_id String
  ledger_transaction    LedgerTransaction @relation(fields: [ledger_transaction_id], references: [id])

  wallet_id             String
  wallet                Wallet            @relation(fields: [wallet_id], references: [id])

  direction             String
  amount                Decimal           @db.Decimal(20, 8)
  currency_code         String
  currency              Currency          @relation(fields: [currency_code], references: [code])

  created_at            DateTime          @default(now())
}

// ==========================================
// 💸 TRANSAÇÕES (CHECKOUT)
// ==========================================
model Transaction {
  id                      String            @id @default(cuid())
  amount                  Decimal           @db.Decimal(15, 2)
  currency                String
  status                  TransactionStatus @default(pending)
  country_code            String
  payment_method          String
  provider_name           String

  fee_amount              Decimal?          @db.Decimal(15, 2) @default(0.0)
  net_amount              Decimal?          @db.Decimal(15, 2) @default(0.0)
  provider_transaction_id String?           @unique

  customer_email          String?
  metadata                Json?

  payee_id                String
  payee                   User              @relation(fields: [payee_id], references: [id])

  store_id                String?
  store                   Store?            @relation(fields: [store_id], references: [id])

  webhook_events          WebhookEvent[]
  clears_at               DateTime? 
  created_at              DateTime          @default(now())
  updated_at              DateTime          @updatedAt
}

model WebhookEvent {
  id              String      @id @default(cuid())
  transaction     Transaction @relation(fields: [transaction_id], references: [id])
  transaction_id  String
  payload         Json
  status          String      @default("pending")
  attempts        Int         @default(0)
  response_code   Int?
  created_at      DateTime    @default(now())
}

model ApiKey {
  id          String   @id @default(cuid())
  name        String
  key_hash    String   @unique
  key_prefix  String
  user_id     String
  user        User     @relation(fields: [user_id], references: [id])
  created_at  DateTime @default(now())
}

model Payout {
  id                String   @id @default(cuid())
  user_id           String
  user              User     @relation(fields: [user_id], references: [id])
  amount            Decimal  @db.Decimal(20, 8)
  currency_code     String
  method            String
  destination       String
  status            String   @default("pending")
  reference_id      String?
  is_manual_ticket  Boolean  @default(false)
  extra_fee_amount  Decimal? @db.Decimal(15, 2)
  metadata          Json?
  resolved_at       DateTime?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
}

model PaymentLink {
  id          String   @id @default(cuid())
  amount      Decimal
  currency    String
  description String?
  slug        String   @unique
  active      Boolean  @default(true)
  userId      String
  storeId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  store       Store?   @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model TierConfig {
  id             String   @id @default(cuid())
  name           String   @unique 
  feeInEur       Decimal
  feeInBrl       Decimal
  feeOutCrypto   Decimal  @default(0)
  feeOutPix      Decimal  @default(0)
  feeOutSepa     Decimal  @default(0)
  feeSwap        Decimal  @default(0)
  defaultBrlProv String   
  defaultEurProv String   
  volLimit       Decimal  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MasterProvider {
  id                   String   @id 
  providerType         String   

  companyName          String   
  merchantOfRecord     String?  
  jurisdiction         String?  

  supportedMethods     String[] 
  supportedCurrencies  String[] 
  allowedRegions       String[] 

  credentials_live     Json?
  credentials_test     Json?
  mode                 String   @default("test") 

  costPercentage       Decimal  @db.Decimal(5, 2) @default(1.40)
  costFixed            Decimal  @db.Decimal(10, 2) @default(0.25)
  settlementDays       Int      @default(2)

  monthlyVolumeLimit   Decimal? @db.Decimal(15, 2)
  currentMonthVolume   Decimal  @db.Decimal(15, 2) @default(0.0)

  priorityScore        Int      @default(100)
  isActive             Boolean  @default(true)
  healthStatus         String   @default("optimal") 

  gateway_configs      GatewayConfig[]

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
